            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{apiKey}}", "type": "text"}
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/health/devices",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "health", "devices"]
            },
            "description": "ANE is FAULTED (kCMErrorUnsupportedOperation), GPU is READY and active. active_tier: 1, active_provider: metal-gpu. next_probe_s: 28 on ANE (probe_attempt 1 → 60s backoff)."
          },
          "response": [
            {
              "name": "200 OK — ANE Faulted, GPU Serving (Tier 1)",
              "status": "OK",
              "code": 200,
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"ane\": {\n    \"state\": \"faulted\",\n    \"since\": \"2025-01-15T10:23:45Z\",\n    \"error\": \"kCMErrorUnsupportedOperation\",\n    \"next_probe_s\": 28,\n    \"probe_attempt\": 1\n  },\n  \"gpu\": {\"state\": \"ready\", \"utilization_pct\": 42},\n  \"cpu\": {\"state\": \"ready\"},\n  \"cloud\": {\"state\": \"ready\", \"policy\": \"allowed\", \"reachable\": true},\n  \"active_tier\": 1,\n  \"active_provider\": \"metal-gpu\"\n}"
            }
          ]
        },
        {
          "name": "GET /v1/health/devices — Both ANE and GPU Faulted (Tier 2, Critical)",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{apiKey}}", "type": "text"}
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/health/devices",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "health", "devices"]
            },
            "description": "Both accelerators quarantined — rare scenario. active_tier: 2 (CPU). GPU probe_attempt: 1 (30s backoff). ANE probe_attempt: 2 (60s backoff). CPU is never quarantined — always state: ready."
          },
          "response": [
            {
              "name": "200 OK — ANE + GPU Faulted, CPU Active (Tier 2, Critical)",
              "status": "OK",
              "code": 200,
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"ane\": {\n    \"state\": \"faulted\",\n    \"since\": \"2025-01-15T10:23:45Z\",\n    \"error\": \"kCMErrorUnsupportedOperation\",\n    \"next_probe_s\": 55,\n    \"probe_attempt\": 2\n  },\n  \"gpu\": {\n    \"state\": \"faulted\",\n    \"since\": \"2025-01-15T10:23:48Z\",\n    \"error\": \"MTLCommandBufferError\",\n    \"next_probe_s\": 18,\n    \"probe_attempt\": 1\n  },\n  \"cpu\": {\"state\": \"ready\"},\n  \"cloud\": {\"state\": \"ready\", \"policy\": \"allowed\", \"reachable\": true},\n  \"active_tier\": 2,\n  \"active_provider\": \"cpu-fallback\"\n}"
            }
          ]
        },
        {
          "name": "GET /v1/health/devices — ANE Probing (Background Check In Progress)",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{apiKey}}", "type": "text"}
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/health/devices",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "health", "devices"]
            },
            "description": "ANE health probe is currently executing: (1) Core ML canary inference with .all, (2) result validation against reference. next_probe_s: 0 = probe is running now. GPU still active during probe — requests continue uninterrupted."
          },
          "response": [
            {
              "name": "200 OK — ANE Probing (Canary Inference Running)",
              "status": "OK",
              "code": 200,
