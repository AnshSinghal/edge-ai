    {
      "name": "6 — ANE Restoration",
      "description": "Requests served after the ANE health probe passes. GPU utilization check also happens — GPU skip if >80% utilized even when ANE is restored.",
      "item": [
        {
          "name": "TTS — First Request After ANE Restored (Back to Tier 0)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{apiKey}}", "type": "text"},
              {"key": "Content-Type", "value": "application/json", "type": "text"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"indic-tts-v3\",\n  \"input\": \"एएनई वापस आ गई है।\",\n  \"params\": {\n    \"temperature\": 0.7\n  }\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{baseUrl}}/v1/inference",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "inference"]
            },
            "description": "ANE probe passed both checks: canary Core ML inference with .all completed without kCMErrorUnsupportedOperation, and result validated against reference.\n\nDevice Manager: FAULTED → READY. Worker heartbeat: device: ane, tier: 0. Scheduler restores queue depth to 64 slots. GPU session destroyed, new ANE session created.\n\nX-Edge-Device-Status: healthy. No X-Edge-Estimated-Restore (not needed when healthy). Latency back to ~8ms/token."
          },
          "response": [
            {
              "name": "200 OK — ANE Restored (Back to Tier 0, ~64ms)",
              "status": "OK",
              "code": 200,
              "header": [
                {"key": "Content-Type", "value": "application/json"},
                {"key": "X-Edge-Compute", "value": "ane"},
                {"key": "X-Edge-Latency-Factor", "value": "1.0"},
                {"key": "X-Edge-Device-Status", "value": "healthy"},
                {"key": "X-Edge-Tier", "value": "0"}
              ],
              "body": "{\n  \"result\": \"<base64-encoded audio data>\",\n  \"model\": \"indic-tts-v3\",\n  \"_meta\": {\n    \"compute\": \"ane\",\n    \"tier\": 0,\n    \"latency_ms\": 65,\n    \"device_status\": \"healthy\"\n  }\n}"
            }
          ]
        },
        {
          "name": "TTS — GPU Utilization >80% (Skips GPU, Falls to CPU Despite ANE Unavailable)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{apiKey}}", "type": "text"},
              {"key": "Content-Type", "value": "application/json", "type": "text"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"indic-tts-v3\",\n  \"input\": \"जीपीयू व्यस्त है।\",\n  \"params\": {\n    \"temperature\": 0.7\n  }\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{baseUrl}}/v1/inference",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "inference"]
