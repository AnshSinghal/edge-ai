              "body": "{\n  \"ane\": {\n    \"state\": \"probing\",\n    \"since\": \"2025-01-15T10:23:45Z\",\n    \"next_probe_s\": 0,\n    \"probe_attempt\": 1\n  },\n  \"gpu\": {\"state\": \"ready\", \"utilization_pct\": 38},\n  \"cpu\": {\"state\": \"ready\"},\n  \"cloud\": {\"state\": \"ready\", \"policy\": \"allowed\", \"reachable\": true},\n  \"active_tier\": 1,\n  \"active_provider\": \"metal-gpu\"\n}"
            }
          ]
