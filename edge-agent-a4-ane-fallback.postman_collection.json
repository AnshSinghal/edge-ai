                {"key": "X-Edge-Compute", "value": "cpu-fallback"},
                {"key": "X-Edge-Latency-Factor", "value": "4.4"},
                {"key": "X-Edge-Device-Status", "value": "critical"},
                {"key": "X-Edge-Tier", "value": "2"}
              ],
              "body": "{\n  \"result\": \"<base64-encoded audio data>\",\n  \"model\": \"indic-tts-v3\",\n  \"_meta\": {\n    \"compute\": \"cpu-fallback\",\n    \"tier\": 2,\n    \"latency_ms\": 115,\n    \"device_status\": \"critical\",\n    \"gpu_skip_reason\": \"high_utilization\"\n  }\n}"
            }
          ]
        }
      ]
    }
